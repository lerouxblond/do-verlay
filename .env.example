# Serveur Go
PORT=8787
# Client ID de ton app Twitch (https://dev.twitch.tv/console) — pour l'échange de code OAuth
TWITCH_CLIENT_ID=ton_client_id_ici
# 127.0.0.1 = boucle locale uniquement (recommandé ; OBS tourne sur la même machine).
# Mettre 0.0.0.0 pour un setup multi-PC, en connaissance de cause.
HOST=127.0.0.1
STATIC_DIR=../frontend/dist

# Base de données (docker-compose + backend Go)
POSTGRES_USER=doverlay
POSTGRES_PASSWORD=changeme
POSTGRES_DB=doverlay
# URL de connexion complète pour le serveur Go (doit correspondre aux vars ci-dessus)
DATABASE_URL=postgres://doverlay:changeme@localhost:5432/doverlay

# Frontend (Vite) — valeur identique à TWITCH_CLIENT_ID, rebuildée dans le JS.
# Nécessite `npm run build` après modification.
VITE_TWITCH_CLIENT_ID=ton_client_id_ici
